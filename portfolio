<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Portfolio — Your Name</title>
  <link rel="stylesheet" href="styles.css" />
</head>
<body class="portfolio-page">
  <p class="top-label"><a href="index.html">← back to home</a></p>

  <header class="portfolio-header">
    <h1>portfolio</h1>
    <p>selected illustrations & experiments</p>
  </header>

  <main class="portfolio-main">
    <section class="portfolio-grid">
      <!-- One block per artwork. Different sizes are fine. -->
      <figure class="portfolio-item">
        <img src="images/portfolio-1.png" alt="Artwork 1" loading="lazy" />
        <figcaption>Title / year / notes</figcaption>
      </figure>

      <figure class="portfolio-item">
        <img src="images/portfolio-2.gif" alt="Artwork 2" loading="lazy" />
        <figcaption>Another piece (GIF works too)</figcaption>
      </figure>

      <!-- copy/paste more <figure> blocks as you add work -->
    </section>
  </main>

  <footer class="bottom">
    <p class="bottom-label">bottom of page</p>
    <p class="credit">© Your Name 2025. Artwork by you.</p>
  </footer>
</body>
</html>
